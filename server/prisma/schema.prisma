generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  displayName  String
  email        String?  @unique
  passwordHash String?
  googleId     String?  @unique
  avatarUrl    String?
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime @default(now())

  sessions         Session[]
  stats            UserStats?
  sentRequests     Friendship[] @relation("FriendRequester")
  receivedRequests Friendship[] @relation("FriendTarget")
  passwordResets   PasswordReset[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model UserStats {
  id          String @id @default(cuid())
  userId      String @unique
  gamesPlayed Int    @default(0)
  gamesWon    Int    @default(0)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Friendship {
  id          String           @id @default(cuid())
  requesterId String
  targetId    String
  status      FriendshipStatus @default(PENDING)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  requester User @relation("FriendRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("FriendTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([targetId])
}

model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

enum FriendshipStatus {
  PENDING
  ACCEPTED
  REJECTED
}
